{
  "name": "rosecloud-iam-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false && node ./scripts/assert-no-token-storage.mjs",
    "generate:api": "node ./scripts/generate-api.mjs",
    "smoke:storage": "node ./scripts/assert-no-token-storage.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-react": "^4.4.1",
    "openapi-typescript": "^7.8.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
